{
  "name": "aapp_web_admin",
  "version": "0.1.0",
  "private": true,
  "homepage": "/beheer/",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "jest",
    "test-ci": "jest --coverage --reporters default --reporters jest-trx-results-processor",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "postinstall": "patch-package",
    "prepare": "husky install",
    "typescript": "npx tsc"
  },
  "dependencies": {
    "@amsterdam/design-system-assets": "^0.2.2",
    "@amsterdam/design-system-css": "^0.13.1",
    "@amsterdam/design-system-react": "^0.13.1",
    "@amsterdam/design-system-tokens": "^0.13.0",
    "@azure/msal-browser": "^3.7.1",
    "@azure/msal-react": "^2.0.10",
    "@eslint/compat": "^2.0.5",
    "@reduxjs/toolkit": "^2.1.0",
    "@sentry/react": "^7.120.4",
    "html-to-image": "^1.11.11",
    "jwt-decode": "^4.0.0",
    "lodash.capitalize": "^4.2.1",
    "lodash.isequal": "^4.5.0",
    "lodash.uniqueid": "^4.0.1",
    "rc-slider": "^10.6.2",
    "react": "^18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^18.2.0",
    "react-easy-crop": "^5.0.6",
    "react-hook-form": "^7.49.3",
    "react-image-upload": "^3.0.1",
    "react-qr-code": "^2.0.12",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.30.3",
    "swagger-ui-react": "^5.32.4"
  },
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.11",
    "@types/lodash.capitalize": "^4.2.9",
    "@types/lodash.isequal": "^4.5.8",
    "@types/lodash.uniqueid": "^4.0.9",
    "@types/node": "^24.12.2",
    "@types/react": "^18.2.48",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^18.2.18",
    "@types/swagger-ui-react": "^4.18.3",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^8.0.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-trx-results-processor": "^3.0.2",
    "lint-staged": "^15.2.4",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "patch-package": "^8.0.1",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(ts|tsx|js|jsx)$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "\\.(css|less|scss|sass)$": "identity-obj-proxy",
      "\\.(gif|png|jpg|jpeg|svg|eot|otf|ttf|woff|woff2)$": "<rootDir>/src/__mocks__/fileMock.ts"
    },
    "coverageReporters": [
      "cobertura",
      "json-summary",
      "json"
    ]
  },
  "volta": {
    "node": "24.15.0"
  }
}
